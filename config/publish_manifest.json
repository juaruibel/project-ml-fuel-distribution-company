{
  "publication_mode": "public_pseudonymous",
  "default_public_root": "../proyecto-ml-public",
  "forbidden_output_roots": [
    "dist",
    "tmp"
  ],
  "managed_paths": [
    ".gitignore",
    ".python-version",
    "LICENSE",
    "README.md",
    "app.py",
    "requirements.txt",
    "requirements-dev.txt",
    "artifacts/public",
    "config",
    "data/public",
    "models/public",
    "notebooks",
    "scripts",
    "src"
  ],
  "cleanup_only_paths": [
    "docs",
    "reports",
    "validations",
    "dist",
    "data/raw",
    "data/staging",
    "data/curated",
    "data/marts",
    "data/synthetic"
  ],
  "publish_allowlist": [
    "notebooks/*.ipynb",
    "src/etl/**/*.py",
    "src/ml/**/*.py",
    "src/sql/**/*",
    "src/prompts/**/*",
    "scripts/publish_to_bootcamp.py",
    "config/**/*",
    "data/public/**/*",
    "models/public/**/*",
    "artifacts/public/**/*"
  ],
  "core_public_datasets": [
    "data/public/dataset_modelo_proveedor_v1.csv",
    "data/public/dataset_modelo_proveedor_v2_candidates.csv",
    "data/public/dataset_modelo_proveedor_v2_excluded_events.csv",
    "data/public/dataset_modelo_proveedor_v3_context.csv",
    "data/public/day041/dataset_modelo_v2_source_quality.csv",
    "data/public/day041/dataset_modelo_v2_dispersion.csv",
    "data/public/day041/dataset_modelo_v2_competition.csv",
    "data/public/day041/dataset_modelo_v2_transport_only.csv",
    "data/public/day042/dataset_modelo_v2_dispersion_plus_transport_rebuilt.csv",
    "data/public/day042/dataset_modelo_v2_transport_rebuilt_only.csv",
    "data/public/day043/dataset_modelo_v2_dispersion_plus_transport_carry30d.csv",
    "data/public/day043/dataset_modelo_v2_transport_carry30d_only.csv",
    "data/public/inference_inputs/example_real_day_2024-05-28.csv"
  ],
  "support_public_artifacts": [
    "artifacts/public/metrics",
    "artifacts/public/models",
    "artifacts/public/notebooks",
    "artifacts/public/sql",
    "artifacts/public/public_publish_manifest.json",
    "artifacts/public/public_audit_summary.json"
  ],
  "sensitive_tokens": [
    "SUPPLIER_012",
    "SUPPLIER_012",
    "Project Author",
    "project_author",
    "proyecto-ml-source",
    "SUPPLIER_DAILY_COMPARISON",
    "/Users/project_author"
  ]
}
